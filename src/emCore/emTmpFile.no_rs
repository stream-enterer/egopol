  class emTmpFileMaster : public emModel
    static emRef<emTmpFileMaster> Acquire(emRootContext & rootContext) -> emRef<emTmpFileMaster>
    emString TryInventPath(const char * postfix=NULL) -> emString
  protected:
    emTmpFileMaster(emContext & context, const emString & name)
